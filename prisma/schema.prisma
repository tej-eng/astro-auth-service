// Department *******************
model Department {
  id          String  @id @default(uuid())
  name        String  @unique
  slug        String  @unique
  description String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staffMembers Staff[]
  isDeleted    Boolean @default(false)
}

// Staff *******************

model Staff {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String

  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  permissions StaffPermission[]

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  isActive  Boolean @default(true)
  isDeleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdAstrologers  Astrologer[] @relation("CreatedAstrologers")
  approvedAstrologers Astrologer[] @relation("ApprovedAstrologers")

  @@index([roleId])
  @@index([departmentId])
}

model StaffPermission {
  id String @id @default(uuid())

  staffId      String
  permissionId String

  staff      Staff      @relation(fields: [staffId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([staffId, permissionId])
}



// dhwani services 
model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique

  services  Service[]

  createdAt DateTime  @default(now())
}

model Service {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  type        ServiceType

  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])

  image       String?
  description String?
  longText    String?
  price       Float?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum ServiceType {
  CATEGORY
  DIRECT_SERVICE
}



model Gift {
  id      String   @id @default(cuid())
  name    String
  amount  Float
  image   String?
  status  String   @default("active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Testimonial 
model Testimonial {
  id        String   @id @default(uuid())
  name      String
  address   String?
  content   String
  image     String?
  rating    Int      // 1 to 5
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// FAQ 
model Faq {
  id        String   @id @default(uuid())
  question  String
  answer    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id            String   @id @default(uuid())

  userId        String
  astrologerId  String

  sessionId     String?  @unique

  rating        Int
  comment       String?

  createdAt     DateTime @default(now())

  user         User       @relation(fields: [userId], references: [id])
  astrologer   Astrologer @relation(fields: [astrologerId], references: [id])
  session      Session?   @relation(fields: [sessionId], references: [id])

  @@index([userId])
  @@index([astrologerId])
}

model Message {
  id        String   @id @default(uuid())

  msgId     String
  roomId    String

  senderId  String
  receiverId String?

  message   String
  image     String?

  sessionId String?
  createdAt DateTime @default(now())

  session Session? @relation(fields: [sessionId], references: [id])

  @@index([roomId])
  @@index([sessionId])
}

model Withdrawal {
  id                String @id @default(uuid())

  astrologerWalletId String
  amount            Float
  coins             Int

  status            WithdrawalStatus

  requestedAt       DateTime @default(now())
  processedAt       DateTime?

  astrologerWallet AstrologerWallet @relation(fields: [astrologerWalletId], references: [id])

  @@index([astrologerWalletId])
  @@index([status])
}
