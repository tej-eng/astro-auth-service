generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////// ENUMS ////////////////////

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ApprovalStatus {
  PENDING
  INTERVIEW
  DOCUMENT_VERIFICATION
  APPROVED
  REJECTED
}

enum InterviewStatus {
  SCHEDULED
  PASSED
  FAILED
  RESCHEDULED
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum DocumentType {
  ID_PROOF
  CERTIFICATE
  EXPERIENCE_PROOF
}

enum RejectionStage {
  PROFILE
  INTERVIEW
  DOCUMENT
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum SessionType {
  CHAT
  CALL
}

enum SessionStatus {
  REQUESTED
  ACCEPTED
  ONGOING
  COMPLETED
  CANCELLED
  FAILED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentProvider {
  RAZORPAY
  STRIPE
  CASHFREE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum PaymentOrderStatus {
  CREATED
  PAID
  FAILED
}

enum PermissionType {
  SYSTEM
  CUSTOM
}

enum CouponType {
  PERCENTAGE
  FLAT
}

enum CouponVisibility {
  PUBLIC
  PRIVATE
}

enum ServiceType {
  CATEGORY
  DIRECT_SERVICE
}

//////////////////// USER ////////////////////

model User {
  id            String   @id @default(uuid())
  name          String?
  countryCode   String?
  mobile        String?
  gender        Gender?
  birthDate     DateTime?
  birthTime     String?
  occupation    String?
  isActive      Boolean  @default(true)
  isDeleted     Boolean  @default(false)
  refreshToken  String?  @db.Text

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  wallet        UserWallet?
  sessions      Session[]
  payments      Payment[]
  paymentOrders PaymentOrder[]
  intakes       Intake[]
  reviews       Review[]

  @@unique([countryCode, mobile])
}

//////////////////// ASTROLOGER ////////////////////

model Astrologer {
  id             String   @id @default(uuid())
  name           String
  displayName    String?
  profilePic     String?
  email          String   @unique
  contactNo      String
  password       String?

  gender         Gender
  experience     Int
  about          String?

  languages      String[]
  skills         String[]

  approvalStatus ApprovalStatus @default(PENDING)
  adminRemarks   String?

  price          Int?   @default(0)
  rating         Float? @default(0)
  status         Boolean @default(false)

  refreshToken   String? @db.Text

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  wallet         AstrologerWallet?
  sessions       Session[]
  reviews        Review[]

  addresses      Address[]
  experiences    ExperiencePlatform[]
  interviews     Interview[]
  documents      AstrologerDocument[]
  rejections     AstrologerRejectionHistory[]
  intakes   Intake[]
}

//////////////////// ADMIN ////////////////////

model Admin {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  phoneNo      String   @unique
  password     String?
  roleId       String

  isActive     Boolean  @default(true)
  isDeleted    Boolean  @default(false)
  refreshToken String?  @db.Text

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  role         Role     @relation(fields: [roleId], references: [id])
}

//////////////////// RBAC ////////////////////

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  admins      Admin[]
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  type        PermissionType @default(SYSTEM)

  createdAt   DateTime @default(now())

  roles       RolePermission[]
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String
  permissionId String

  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
}

//////////////////// WALLET ////////////////////

model UserWallet {
  id           String @id @default(uuid())
  userId       String @unique

  balanceCoins Float  @default(0)
  lockedCoins  Float  @default(0)

  user         User   @relation(fields: [userId], references: [id])
  transactions WalletTransaction[]
}

model AstrologerWallet {
  id           String @id @default(uuid())
  astrologerId String @unique

  balanceCoins Float @default(0)

  astrologer   Astrologer @relation(fields: [astrologerId], references: [id])
  transactions WalletTransaction[]
  withdrawals  Withdrawal[]
}

model WalletTransaction {
  id                String @id @default(uuid())

  userWalletId      String?
  astrologerWalletId String?

  sessionId         String?
  paymentId         String?

  coins             Int
  amount            Float?
  type              TransactionType

  createdAt         DateTime @default(now())

  userWallet        UserWallet?       @relation(fields: [userWalletId], references: [id])
  astrologerWallet  AstrologerWallet? @relation(fields: [astrologerWalletId], references: [id])
  session           Session?          @relation(fields: [sessionId], references: [id])
  payment           Payment?          @relation(fields: [paymentId], references: [id])

  @@unique([paymentId, type])
}

//////////////////// SESSION ////////////////////

model Session {
  id            String @id @default(uuid())

  userId        String
  astrologerId  String

  type          SessionType
  status        SessionStatus

  ratePerMin    Int?
  durationSec   Int @default(0)

  coinsDeducted Int @default(0)
  coinsEarned   Int @default(0)

  startedAt     DateTime?
  endedAt       DateTime?

  createdAt     DateTime @default(now())

  user          User       @relation(fields: [userId], references: [id])
  astrologer    Astrologer @relation(fields: [astrologerId], references: [id])

  transactions  WalletTransaction[]
  review        Review?
  messages      Message[]
}

//////////////////// PAYMENT ////////////////////

model Payment {
  id             String @id @default(uuid())

  userId         String
  rechargePackId String

  amount         Float
  coins          Int?

  provider       PaymentProvider?
  razorpayPaymentId String? @unique

  status         PaymentStatus

  createdAt      DateTime @default(now())

  user           User @relation(fields: [userId], references: [id])
  rechargePack   RechargePack @relation(fields: [rechargePackId], references: [id])

  transactions   WalletTransaction[]
}

model PaymentOrder {
  id        String @id @default(uuid())
  userId    String
  amount    Float

  user      User @relation(fields: [userId], references: [id])
}

//////////////////// CHAT ////////////////////

model Message {
  id        String @id @default(uuid())

  msgId     String
  roomId    String

  senderId  String
  receiverId String?

  message   String
  image     String?

  sessionId String?
  session   Session? @relation(fields: [sessionId], references: [id])

  createdAt DateTime @default(now())
}

//////////////////// REVIEW ////////////////////

model Review {
  id           String @id @default(uuid())

  userId       String
  astrologerId String
  sessionId    String? @unique

  rating       Int
  comment      String?

  createdAt    DateTime @default(now())

  user         User       @relation(fields: [userId], references: [id])
  astrologer   Astrologer @relation(fields: [astrologerId], references: [id])
  session      Session?   @relation(fields: [sessionId], references: [id])
}

//////////////////// OTHER ////////////////////

model RechargePack {
  id        String @id @default(uuid())
  name      String
  price     Float
  coins     Int
  talktime  Int

  createdAt DateTime @default(now())

  payments  Payment[]
}

model Withdrawal {
  id                String @id @default(uuid())

  astrologerWalletId String
  amount            Float
  coins             Int

  status            WithdrawalStatus

  requestedAt       DateTime @default(now())

  astrologerWallet  AstrologerWallet @relation(fields: [astrologerWalletId], references: [id])
}

model Address {
  id           Int @id @default(autoincrement())
  astrologerId String

  street String
  city   String
  state  String

  astrologer Astrologer @relation(fields: [astrologerId], references: [id])
}

model ExperiencePlatform {
  id           Int @id @default(autoincrement())
  astrologerId String
  platformName String
  yearsWorked  Int

  astrologer Astrologer @relation(fields: [astrologerId], references: [id])
}

model Interview {
  id           Int @id @default(autoincrement())
  astrologerId String
  roundNumber  Int
  status       InterviewStatus

  astrologer Astrologer @relation(fields: [astrologerId], references: [id])
}

model AstrologerDocument {
  id           Int @id @default(autoincrement())
  astrologerId String
  documentType DocumentType
  documentUrl  String

  astrologer Astrologer @relation(fields: [astrologerId], references: [id])
}

model AstrologerRejectionHistory {
  id           Int @id @default(autoincrement())
  astrologerId String
  stage        RejectionStage
  reason       String

  astrologer Astrologer @relation(fields: [astrologerId], references: [id])
}

model Intake {
  id           String   @id @default(uuid())

  userId       String
  astrologerId String

  chatId       String?

  name         String
  countryCode  String?
  mobile       String?

  gender       Gender?
  birthDate    DateTime?
  birthTime    String?

  occupation   String?
  birthPlace   String?
  requestType  String?

  createdAt    DateTime @default(now())

  user         User       @relation(fields: [userId], references: [id])
  astrologer   Astrologer @relation(fields: [astrologerId], references: [id])

  @@index([userId])
  @@index([astrologerId])
}